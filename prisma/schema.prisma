generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         @default("#6b7280")
  icon          String         @default("shopping-cart")
  createdAt     DateTime       @default(now())
  transactions  Transaction[]
  budgets       Budget[]
  merchantRules MerchantRule[]
}

model Transaction {
  id          String    @id @default(cuid())
  date        DateTime
  amount      Int
  description String
  store       String?
  source      String    @default("manual")
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  importId    String?

  @@index([date])
  @@index([categoryId])
}

model MerchantRule {
  id         String   @id @default(cuid())
  merchant   String   @unique
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())
}

model Budget {
  id         String   @id @default(cuid())
  month      String
  amount     Int
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([month, categoryId])
}
